<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.leetcode.leetcode_ai.problem.mapper.ProblemMapper">

    <resultMap id="problemResultMap" type="com.leetcode.leetcode_ai.problem.entity.Problem">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="inputDesc" column="input_desc"/>
        <result property="outputDesc" column="output_desc"/>
        <result property="difficulty" column="difficulty"/>
        <result property="knowledgePoints" column="knowledge_points"/>
        <result property="supportLanguages" column="support_languages"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="onlineFilter">
        p.status = 1
    </sql>

    <sql id="queryCondition">
        <where>
            <include refid="onlineFilter"/>
            <if test="keyword != null and keyword != ''">
                and (p.title like concat('%', #{keyword}, '%') or p.content like concat('%', #{keyword}, '%'))
            </if>
            <if test="difficulty != null and difficulty != ''">
                and p.difficulty = #{difficulty}
            </if>
            <if test="tagId != null">
                and exists (
                    select 1
                    from problem_tags pt2
                    where pt2.problem_id = p.id
                      and pt2.tag_id = #{tagId}
                )
            </if>
        </where>
    </sql>

    <select id="countByCondition" resultType="long">
        select count(1)
        from problems p
        <include refid="queryCondition"/>
    </select>

    <select id="findPageByCondition" resultMap="problemResultMap">
        select p.id, p.title, p.content, p.input_desc, p.output_desc, p.difficulty, p.knowledge_points,
               p.support_languages, p.status, p.created_at, p.updated_at
        from problems p
        <include refid="queryCondition"/>
        order by p.created_at desc, p.id desc
        limit #{size} offset #{offset}
    </select>

    <select id="findTagsByProblemIds" resultType="com.leetcode.leetcode_ai.problem.mapper.row.ProblemTagRow">
        select pt.problem_id as problemId, t.tag_name as tagName
        from problem_tags pt
                 join tags t on t.id = pt.tag_id
        where pt.problem_id in
        <foreach collection="problemIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="findOnlineById" resultMap="problemResultMap">
        select p.id, p.title, p.content, p.input_desc, p.output_desc, p.difficulty, p.knowledge_points,
               p.support_languages, p.status, p.created_at, p.updated_at
        from problems p
        where p.id = #{id}
          and <include refid="onlineFilter"/>
        limit 1
    </select>

    <select id="findTagNamesByProblemId" resultType="string">
        select t.tag_name
        from problem_tags pt
                 join tags t on t.id = pt.tag_id
        where pt.problem_id = #{problemId}
        order by t.id asc
    </select>

</mapper>
