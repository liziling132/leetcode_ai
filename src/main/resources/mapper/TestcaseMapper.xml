<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.leetcode.leetcode_ai.testcase.mapper.TestcaseMapper">

    <resultMap id="testcaseResultMap" type="com.leetcode.leetcode_ai.testcase.entity.Testcase">
        <id property="id" column="id"/>
        <result property="problemId" column="problem_id"/>
        <result property="caseType" column="case_type"/>
        <result property="inputData" column="input_data"/>
        <result property="outputData" column="output_data"/>
        <result property="score" column="score"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="isActive" column="is_active"/>
    </resultMap>

    <select id="findActiveByProblemId" resultMap="testcaseResultMap">
        select id, problem_id, case_type, input_data, output_data, score, sort_order, is_active
        from testcases
        where problem_id = #{problemId}
          and is_active = 1
        order by sort_order asc, id asc
    </select>

</mapper>
